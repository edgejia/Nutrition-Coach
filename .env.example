OPENAI_API_KEY=your-api-key-here
OPENAI_ORCHESTRATOR_MODEL=gpt-5.4-mini
PORT=3000
DB_PATH=./data/nutrition.db
# All day-boundary logic uses the process timezone. Set explicitly for consistent behavior.
TZ=Asia/Taipei

# Optional deployment overrides. Local development can use the built-in defaults.
# NODE_ENV=production
# GUEST_SESSION_SECRET should be a stable random value in shared/deployed environments.
# GUEST_SESSION_SECRET=replace-me-with-random-secret
# ASSETS_DIR=./data/assets
# UPLOADS_STAGING_DIR=./data/uploads-staging
# CLIENT_DIST_DIR=./dist/client
