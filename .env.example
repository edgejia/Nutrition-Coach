OPENAI_API_KEY=your-api-key-here
OPENAI_ORCHESTRATOR_MODEL=gpt-5-nano
GUEST_SESSION_SECRET=replace-me-for-shared-beta
GUEST_SESSION_COOKIE_NAME=guest_session
GUEST_SESSION_RESUME_COOKIE_NAME=guest_session_resume
GUEST_SESSION_TTL_SECONDS=43200
GUEST_SESSION_RESUME_TTL_SECONDS=2592000
GUEST_SESSION_COOKIE_SECURE=false
