{
  "name": "nutrition-coach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node --env-file=.env --import tsx --watch server/index.ts",
    "dev:client": "vite dev --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "release:check": "node scripts/run-node-with-tz.mjs --env-file=.env scripts/release-check.mjs",
    "pr:policy": "node scripts/pr-policy-check.mjs",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "node --import tsx server/db/migrate.ts",
    "start": "node --import tsx server/index.ts",
    "test": "node scripts/run-node-with-tz.mjs --import tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:unit": "node scripts/run-node-with-tz.mjs --import tsx --test tests/unit/*.test.ts",
    "test:integration": "node scripts/run-node-with-tz.mjs --import tsx --test tests/integration/*.test.ts",
    "verify:harness": "node scripts/run-node-with-tz.mjs --import tsx tests/harness/run.ts",
    "matrix:gen": "node --import tsx scripts/generate-capability-matrix-doc.mjs",
    "matrix:gen:check": "node --import tsx scripts/generate-capability-matrix-doc.mjs --check",
    "matrix:check": "node scripts/run-node-with-tz.mjs --import tsx --test tests/unit/capability-matrix-contract.test.ts tests/unit/capability-matrix-source-scan.test.ts && yarn matrix:gen:check",
    "behavior-matrix:gen": "node --import tsx scripts/generate-behavior-matrix-doc.mjs",
    "behavior-matrix:gen:check": "node --import tsx scripts/generate-behavior-matrix-doc.mjs --check",
    "policy-taxonomy:gen": "node --import tsx scripts/generate-policy-taxonomy-doc.mjs",
    "policy-taxonomy:gen:check": "node --import tsx scripts/generate-policy-taxonomy-doc.mjs --check",
    "policy-taxonomy:check": "node scripts/run-node-with-tz.mjs --import tsx --test tests/unit/policy-taxonomy-doc.test.ts && yarn policy-taxonomy:gen:check"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "9.1.3",
    "better-sqlite3": "^11.8.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "5.8.5",
    "openai": "^4.82.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  },
  "resolutions": {
    "brace-expansion": "5.0.6",
    "fast-uri": "3.1.2"
  }
}
