{
  "name": "nutrition-coach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "node --env-file=.env --import tsx --watch server/index.ts",
    "dev:client": "vite dev --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "test": "node --import tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/*.test.ts"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/cors": "^11.0.0",
    "drizzle-orm": "^0.39.0",
    "better-sqlite3": "^11.8.0",
    "openai": "^4.82.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0"
  }
}
