{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "jsx": "react-jsx"
  },
  "include": ["server/**/*.ts", "tests/**/*.ts", "client/src/**/*.ts", "client/src/**/*.tsx", "client/vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
